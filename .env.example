# ──────────────────────────────────────────────────────────────────────────────
# KLô — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs.
# Ne committez JAMAIS .env.local dans git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase (OBLIGATOIRE en production) ──────────────────────────────────────
# Trouvez ces valeurs dans : Supabase Dashboard → Project Settings → API

# URL du projet (exposée côté client — pas de secrets)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clé anonyme (exposée côté client — accès limité par RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clé service role (SECRÈTE — uniquement API routes server-side)
# Bypass complet des RLS — ne jamais exposer côté client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── CinetPay — Paiement Mobile Money / Carte (OBLIGATOIRE en production) ──────
# Trouvez ces valeurs dans : dashboard.cinetpay.com → Mes applications

CINETPAY_API_KEY=your_cinetpay_api_key_here
CINETPAY_SITE_ID=your_cinetpay_site_id_here

# Clé secrète pour vérifier la signature HMAC des webhooks CinetPay
# Configurez cette valeur dans le dashboard CinetPay → Webhooks
CINETPAY_WEBHOOK_SECRET=your_cinetpay_webhook_secret_here

# ── Resend — Emails transactionnels (OPTIONNEL — logs console si absent) ──────
# Créez un compte sur resend.com, vérifiez votre domaine, puis créez une API Key

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email expéditeur (doit correspondre à un domaine vérifié dans Resend)
RESEND_FROM_EMAIL=KLô Immobilier <contact@klo.immo>

# ── Taux de marge KLô (OPTIONNEL — défaut 5%) ─────────────────────────────────
# Pourcentage de marge appliqué sur le prix d'achat terrain (entre 5 et 6)
NEXT_PUBLIC_MARGE_TAUX=5

# ── URL publique de l'app (OPTIONNEL — auto-détecté par Next.js) ──────────────
# Utile pour les liens dans les emails et les webhooks
NEXT_PUBLIC_APP_URL=https://klo.immo

# ── Vercel (auto-injectées par Vercel, ne pas renseigner manuellement) ─────────
# VERCEL_URL=klo.vercel.app
# NEXT_PUBLIC_VERCEL_URL=klo.vercel.app
